# ---- AWS Bedrock ----
# Credentials are resolved from the standard AWS chain (env vars, shared
# profile, SSO, instance role). Set these OR configure `aws configure`.
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...

# Bedrock model id (or inference-profile id, e.g. us.anthropic.claude-sonnet-5).
BEDROCK_MODEL_ID=anthropic.claude-sonnet-5

# ---- Your GraphQL API ----
GRAPHQL_ENDPOINT=https://your-api.example.com/graphql
# Path to the SDL schema file used to auto-generate tools.
GRAPHQL_SCHEMA_PATH=sample.graphql
# Auth header sent with every GraphQL request (optional).
GRAPHQL_AUTH_HEADER=Authorization
GRAPHQL_AUTH_TOKEN=Bearer your-token-here
# Extra headers as JSON — some gateways require an allowlisted Origin.
# GRAPHQL_EXTRA_HEADERS={"Origin": "http://localhost:3000"}

# ---- Langfuse observability ----
# Tracing turns on automatically when both keys are present. Get them from your
# Langfuse project settings (cloud.langfuse.com or your self-hosted instance).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ---- Orchestrator tuning ----
MAX_TOKENS=16000
# Max agent<->tools cycles before giving up (guards against runaway loops).
MAX_TURNS_LIMIT=12
# Expose write (mutation) tools. Default false = read-only (queries only).
ALLOW_MUTATIONS=false
# Narrow large schemas with regexes matched on tool (field) names. Empty = all.
# Example for a lender-portal token: TOOL_INCLUDE=^Lender_
TOOL_INCLUDE=
TOOL_EXCLUDE=
